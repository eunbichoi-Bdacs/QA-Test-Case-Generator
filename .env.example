# 이 파일을 복사해 `.env` 로 저장한 뒤, [필수]만 최소한 고치면 됩니다.
# 예: cp .env.example .env

# =============================================================================
# [필수] API 서버 (npm run dev 시 8787) — 값을 꼭 바꾸세요
# =============================================================================
# 아무 긴 랜덤 문자열 (16자 이상). 예: openssl rand -base64 32
JWT_SECRET=여기에_16자_이상_랜덤으로_바꾸세요

# =============================================================================
# [배포 시] 백엔드 API 전체 URL (프론트만 Vercel에 올린 경우 필수에 가깝게)
# 끝에 / 붙이지 않음. 예: https://qa-api-xxxx.up.railway.app
# VITE_API_BASE_URL=https://your-api-host.example.com

# =============================================================================
# [권장] 클라이언트 (Vite) — 로컬에서 바로 쓰기 좋은 기본값
# =============================================================================
# true 이면 TC 생성은 목업(서버 호출 없음). false 로 두려면 아래 URL·업스트림 필요.
VITE_USE_MOCK=true

# 목업이 아니고, 같은 머신의 통합 API로 TC 생성할 때 (프록시 /api → 8787)
# VITE_USE_MOCK=false 일 때만 의미 있음
VITE_TC_API_URL=/api

# =============================================================================
# [선택] Google 로그인 — 버튼·서버 검증 둘 다 쓰려면 두 줄에 같은 클라이언트 ID
# =============================================================================
# VITE_GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com
# GOOGLE_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# =============================================================================
# [선택] API 서버만 (대부분 기본값 그대로 두면 됨)
# =============================================================================
# SQLite 경로 (기본: 프로젝트/data/app.db)
# DATABASE_PATH=./data/app.db

# CORS 허용 오리진 (프론트 주소가 다르면 수정)
# CLIENT_ORIGIN=http://localhost:5173

# TC 생성을 다른 백엔드로 넘길 때만. {이 URL}/generate-tc 로 프록시됨
# TC_GENERATE_UPSTREAM_URL=http://127.0.0.1:9999/api
